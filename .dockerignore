# Build-context exclusions — keep the image small and reproducible.
# Anything listed here never enters the build context sent to the daemon.

# --- VCS + editor + hidden local state -------------------------------------
.*
.vscode
.idea
.DS_Store

# --- Python runtime state ---------------------------------------------------
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
.coverage.*
htmlcov
.tox
.nox

# --- Virtualenvs ------------------------------------------------------------
.venv
venv
env

# --- Local data / logs / caches --------------------------------------------
data
logs
*.log
*.db
*.db-journal
*.db-wal
*.db-shm

# --- Docs + tests NOT needed inside the runtime image -----------------------
tests
docs
scripts/*
!scripts/verify_webui_artifact.py
CHANGELOG.md
KNOWN_LIMITATIONS.md

# --- Install scripts (shipped at repo root for host-side install) ----------
install.sh
install.ps1

# --- Secrets + local config (never shipped) --------------------------------
.env*
**/.env*
.npmrc
**/.npmrc
*.pem
**/*.pem
*.key
**/*.key

# --- Build artefacts --------------------------------------------------------
dist
build
*.egg-info
**/node_modules
opensquilla-webui/test-results

# The WebUI bundle is rebuilt in the builder stage. Never merge a local,
# potentially stale bundle into the generated artifact copied from that stage.
src/opensquilla/gateway/static/dist

# --- CI / local tooling -----------------------------------------------------
uv.lock
.pre-commit-config.yaml
